# Instance Configuration
PUBLIC_APP_URL=http://localhost
NODE_ENV=development

# Database
POSTGRES_DB=lancerhub
POSTGRES_USER=lancerhub
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://lancerhub:change-me-in-production@postgres:5432/lancerhub

# Redis
REDIS_URL=redis://redis:6379

# Storage (MinIO for self-hosted, S3 for cloud)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-in-production
S3_BUCKET=lancerhub
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Authentication
JWT_SECRET=change-me-to-a-strong-random-secret-in-production
JWT_EXPIRES_IN=7d

# Email (Required for production)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@yourdomain.com

# Stripe (Required for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# API Configuration
API_HOST=0.0.0.0
API_PORT=3001
WEB_PORT=3000

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false