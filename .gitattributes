# === Git Attributes for LancerHub Monorepo ===

# === Text Files ===
* text=auto eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf

# === Configuration Files ===
*.env text eol=lf
*.config.* text eol=lf
Dockerfile* text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# === Shell Scripts ===
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# === Binary Files ===
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.tgz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# === Large File Storage (if needed) ===
# *.zip filter=lfs diff=lfs merge=lfs -text
# *.tar.gz filter=lfs diff=lfs merge=lfs -text
# *.pdf filter=lfs diff=lfs merge=lfs -text

# === Language-specific ===
*.sql linguist-language=SQL
*.prisma linguist-language=Prisma
package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
*.d.ts linguist-generated=true

# === Merge Strategies ===
package.json merge=ours
package-lock.json merge=ours
.gitignore merge=union