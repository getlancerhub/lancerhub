logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids
*.pid
*.seed
*.pid.lock

# === Runtime & Temporary ===
.npm
.eslintcache
.node_repl_history
*.tmp
*.temp
.tmp/
.temp/

# === Test Coverage ===
coverage/
.nyc_output
.coverage
*.lcov

# === TypeScript ===
*.tsbuildinfo
.tscache/

# === Next.js ===
.next/
out/
next-env.d.ts

# === Docker ===
.dockerignore
docker-compose.override.local.yml

# === Database ===
*.db
*.sqlite
*.sqlite3
/data/
/postgres-data/
/redis-data/
/minio-data/

